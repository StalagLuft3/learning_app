generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model employees {
  employeeID            Int                     @id @default(autoincrement())
  username              String
  role                  String
  email                 String
  password              String
  managed_assessments   assessments[]           @relation("AssessmentManager")
  managed_courses       courses[]               @relation("CourseManager")
  employees_assessments employees_assessments[]
  employees_courses     employees_courses[]
  employees_experiences employees_experiences[] @relation("EmployeeExperiences")
  referee_experiences   employees_experiences[] @relation("RefereeExperiences")
  managed_pathways      pathways[]              @relation("PathwayManager")
  pathways_employees    pathways_employees[]

  @@map("employees")
}

model assessments {
  assessmentID          Int                     @id @default(autoincrement())
  name                  String
  description           String
  delivery_method       String
  delivery_location     String
  duration              Float
  manager_ID            Int
  max_score             Int
  passing_score         Int
  expiry                Int?
  manager               employees               @relation("AssessmentManager", fields: [manager_ID], references: [employeeID])
  employees_assessments employees_assessments[]
  pathways_assessments  pathways_assessments[]

  @@map("assessments")
}

model courses {
  courseID          Int                 @id @default(autoincrement())
  courseName        String
  description       String?
  delivery_method   String?
  delivery_location String?
  duration          Float
  courseManagerID   Int
  manager           employees           @relation("CourseManager", fields: [courseManagerID], references: [employeeID])
  employees_courses employees_courses[]
  pathways_courses  pathways_courses[]

  @@map("courses")
}

model employees_courses {
  employee_courseID Int       @id @default(autoincrement())
  employeeID        Int
  courseID          Int
  currentStatus     String
  recordDate        String
  // completionDate removed as per deduplication
  score             Int?
  courses           courses   @relation(fields: [courseID], references: [courseID])
  employees         employees @relation(fields: [employeeID], references: [employeeID])

  @@map("employees_courses")
}

model experience_templates {
  experience_templateID         Int                             @id @default(autoincrement())
  experienceDescription         String
  minimumDuration               Float
  pathways_experience_templates pathways_experience_templates[]

  @@map("experience_templates")
}

model employees_assessments {
  employee_assessmentID Int         @id @default(autoincrement())
  employeeID            Int
  assessmentID          Int
  currentStatus         String?
  recordDate            String
  // completionDate removed as per deduplication
  score                 Int?
  assessments           assessments @relation(fields: [assessmentID], references: [assessmentID])
  employees             employees   @relation(fields: [employeeID], references: [employeeID])

  @@map("employees_assessments")
}

model employees_experiences {
  employee_experienceID Int        @id @default(autoincrement())
  experience_templateID Int?
  experienceDescription String
  duration              Float
  recordDate            String
  employeeID            Int
  employeeText          String?
  refereeID             Int?
  refereeText           String?
  employees             employees  @relation("EmployeeExperiences", fields: [employeeID], references: [employeeID])
  referee               employees? @relation("RefereeExperiences", fields: [refereeID], references: [employeeID])

  @@map("employees_experiences")
}

model feedback {
  feedbackID            Int     @id @default(autoincrement())
  refererID             Int
  refereeID             Int
  employee_experienceID Int
  actioned              Boolean @default(false)

  @@map("feedback")
}

model pathways {
  pathwayID                     Int                             @id @default(autoincrement())
  pathwayName                   String
  pathwayDescription            String
  pathwayManagerID              Int
  enrollment_status             String?
  some_numeric_value            Int?
  record_date                   DateTime?
  manager                       employees                       @relation("PathwayManager", fields: [pathwayManagerID], references: [employeeID])
  pathways_assessments          pathways_assessments[]
  pathways_courses              pathways_courses[]
  pathways_employees            pathways_employees[]
  pathways_experience_templates pathways_experience_templates[]

  @@map("pathways")
}

model pathways_assessments {
  pathway_assessmentID Int         @id @default(autoincrement())
  pathwayID            Int?
  assessmentID         Int
  assessments          assessments @relation(fields: [assessmentID], references: [assessmentID])
  pathways             pathways?   @relation(fields: [pathwayID], references: [pathwayID], onDelete: Cascade)

  @@map("pathways_assessments")
}

model pathways_courses {
  pathway_courseID Int       @id @default(autoincrement())
  pathwayID        Int?
  courseID         Int
  courses          courses   @relation(fields: [courseID], references: [courseID])
  pathways         pathways? @relation(fields: [pathwayID], references: [pathwayID], onDelete: Cascade)

  @@map("pathways_courses")
}

model pathways_employees {
  pathway_employeeID Int       @id @default(autoincrement())
  pathwayID          Int?
  employeeID         Int
  recordDate         String
  employees          employees @relation(fields: [employeeID], references: [employeeID])
  pathways           pathways? @relation(fields: [pathwayID], references: [pathwayID], onDelete: Cascade)

  @@map("pathways_employees")
}

model pathways_experience_templates {
  pathway_experience_templateID Int                  @id @default(autoincrement())
  pathwayID                     Int?
  experience_templateID         Int
  experience_templates          experience_templates @relation(fields: [experience_templateID], references: [experience_templateID])
  pathways                      pathways?            @relation(fields: [pathwayID], references: [pathwayID], onDelete: Cascade)

  @@map("pathways_experience_templates")
}
